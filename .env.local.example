# ── Sanity CMS ──────────────────────────────────────────────────────────
# Get Project ID from sanity.io → your project → Settings → API
NEXT_PUBLIC_SANITY_PROJECT_ID=xxxxxxxx
NEXT_PUBLIC_SANITY_DATASET=production
# Read token: sanity.io → Settings → API → Tokens → Add API token (Viewer)
SANITY_API_TOKEN=sk...
# Write token (Editor) — only needed to run scripts/seed-focusly.mjs locally
SANITY_WRITE_TOKEN=sk...
# Shared secret for the Studio → /api/revalidate webhook (any random string)
SANITY_REVALIDATE_SECRET=...

# ── Resend (contact form) ────────────────────────────────────────────────
RESEND_API_KEY=re_...
